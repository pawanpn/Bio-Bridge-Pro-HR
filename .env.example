# ============================================================
# Bio-Bridge Pro HR — Environment Variables Template
# Copy this to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.
#
# !! ACTION REQUIRED: If .env was already committed to git,
#    rotate all keys below IMMEDIATELY:
#    Supabase Dashboard → Settings → API → Regenerate keys
# ============================================================

# ── Supabase (Cloud sync) ────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key — ONLY used server-side (Rust backend).
# NEVER expose this to the frontend / VITE_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── App ──────────────────────────────────────────────────────
VITE_APP_NAME="Bio-Bridge Pro HR"
VITE_APP_VERSION="1.0.0"

# ── Encryption ───────────────────────────────────────────────
# AES-256 key for field-level encryption (32 bytes, hex-encoded).
# Generate with: openssl rand -hex 32
# This must be stored in the OS keyring in production,
# NOT in this file. This env var is only used in development.
ENCRYPTION_KEY=your_32_byte_hex_key_here

# ── SQLite (local database path) ─────────────────────────────
# Leave empty to use Tauri's default app data directory.
DB_PATH=

# ── Feature flags ────────────────────────────────────────────
VITE_ENABLE_CLOUD_SYNC=true
VITE_ENABLE_BIOMETRIC=true
VITE_ENABLE_MOBILE=false
VITE_DEBUG_MODE=false
